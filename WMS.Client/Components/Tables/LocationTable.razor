@using MudBlazor

<MudCard Elevation="2" Class="pa-4">
    <MudTable Items="@Items"
              Hover="true"
              Dense="true"
              Elevation="0"
              Filter="FilterFunc"
              AllowUnsorted="false"
              InitialDirection="SortDirection.Descending"
              Loading="@(Items == null)">
        <ToolBarContent>
            <MudText Typo="Typo.h4"
                     Color="Color.Primary"
                     Class="mb-6">
                Locations
            </MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString"
                          Immediate="true"
                          Placeholder="Search location..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Clearable="true" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<string, object>(x => x)">
                    Location Code
                </MudTableSortLabel>
            </MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Location Code">
                <MudChip T="string"
                         Size="Size.Small"
                         Variant="Variant.Outlined">
                        @context
                </MudChip>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>

</MudCard>
@code {
    [Parameter]
    public IEnumerable<string>? Items { get; set; }

    private string _searchString = string.Empty;

    private bool FilterFunc(string element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
        {
            return true;
        }

        var search = _searchString.Trim();

        return element.Contains(
            search,
            StringComparison.OrdinalIgnoreCase);
    }
}