@using MudBlazor
@using WMS.Application.Products.Response
@using WMS.Application.Stocks.Responses

<MudTable Items="@Items"
          Hover="true"
          Dense="true"
          Elevation="0"
          Filter="@(new Func<LowStockProductResponse, bool>(FilterFunc))">
    <ToolBarContent>
        <MudText Typo="Typo.h4"
                 Color="Color.Primary"
                 Class="mb-6">
             Low Stock Products
        </MudText>

        <MudSpacer />

        <MudTextField @bind-Value="_searchString"
                      Immediate="true"
                      Placeholder="Search products..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Clearable="true" />
    </ToolBarContent>

    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<LowStockProductResponse, object>(x => x.ProductName)">
                Product
            </MudTableSortLabel>
        </MudTh>

        <MudTh>
            <MudTableSortLabel SortBy="new Func<LowStockProductResponse, object>(x => x.ProductSku)">
                SKU
            </MudTableSortLabel>
        </MudTh>

        <MudTh>
            <MudTableSortLabel SortBy="new Func<LowStockProductResponse, object>(x => x.Quantity)">
                Quantity
            </MudTableSortLabel>
        </MudTh>

        <MudTh>
            Status
        </MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="Product">
            <MudText Typo="Typo.body2">
                @context.ProductName
            </MudText>
        </MudTd>

        <MudTd DataLabel="SKU">
            <MudChip T="string"
                     Size="Size.Small"
                     Variant="Variant.Outlined">
                @context.ProductSku
            </MudChip>
        </MudTd>

        <MudTd DataLabel="Quantity">
            <MudText Color="Color.Error"
                     Style="font-weight:600">
                @context.Quantity
            </MudText>
        </MudTd>

        <MudTd DataLabel="Status">
            <MudChip T="string"
                     Color="Color.Warning"
                     Size="Size.Small"
                     Variant="Variant.Filled">
                Low Stock
            </MudChip>
        </MudTd>
    </RowTemplate>

    <NoRecordsContent>
        <MudText Class="pa-4">
            No low stock products.
        </MudText>
    </NoRecordsContent>

    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 5, 10, 25 }" />
    </PagerContent>
</MudTable>

@code {
    [Parameter]
    public IEnumerable<LowStockProductResponse>? Items { get; set; }

    private string _searchString = string.Empty;

    private bool FilterFunc(LowStockProductResponse element)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
        {
            return true;
        }

        var search = _searchString.Trim();
        return
            element.ProductName?.Contains(search, StringComparison.OrdinalIgnoreCase) == true ||
            element.ProductSku?.Contains(search, StringComparison.OrdinalIgnoreCase) == true;
    }
}