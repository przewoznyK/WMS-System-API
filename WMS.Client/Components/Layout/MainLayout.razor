@inject NavigationManager Navigation

@using WMS.Client.Services.Interfaces
@using WMS.Domain.Enums
@using MudBlazor
@using System.Security.Claims

@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" IsDarkMode="@_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    @if (!IsLoginPage)
    {
        <MudAppBar Elevation="1" Color="Color.Surface">

            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                            Color="Color.Primary"
                            Edge="Edge.Start"
                            OnClick="@DrawerToggle" />

            <MudButton Href="/"
                        Variant="Variant.Text"
                        Color="Color.Primary"
                        Class="px-2">

                <MudIcon Icon="@Icons.Material.Filled.Widgets"
                            Size="Size.Large"
                            Class="mr-2" />

                <MudText Typo="Typo.h5"
                            Style="font-weight:700; letter-spacing:1px;">
                    WMS
                </MudText>
            </MudButton>
            <MudSpacer />
            <MudIconButton Icon="@(_isDarkMode 
                    ? Icons.Material.Filled.WbSunny 
                    : Icons.Material.Filled.DarkMode)"
                            Color="Color.Primary"
                            OnClick="ToggleDarkMode"
                            Class="mr-2" />
        @if (_isLoggedIn)
        {
            <MudMenu AnchorOrigin="Origin.BottomRight"
                        TransformOrigin="Origin.TopRight">

                <ActivatorContent>
                    <MudButton Variant="Variant.Text"
                                Color="Color.Primary"
                                OnClick="@context.ToggleAsync">

                        <MudIcon Icon="@GetRoleIcon()"
                                    Class="mr-2" />
                            @_email
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" />
                    </MudButton>
                </ActivatorContent>

                <ChildContent>
                    <MudMenuItem OnClick="Logout">
                        <MudIcon Icon="@Icons.Material.Filled.Logout"
                                    Class="mr-2" />
                        Logout
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        Href="/login">

                <MudIcon Icon="@Icons.Material.Filled.Login"
                            Class="mr-2" />
                Login
            </MudButton>
        }

        </MudAppBar>
        <MudDrawer @bind-Open="_drawerOpen"
                    Elevation="2"
                    ClipMode="DrawerClipMode.Always"
                    Variant="DrawerVariant.Responsive">

            <NavMenu UserRole="_role" />
        </MudDrawer>
    }

    <MudMainContent>
        @if (IsLoginPage)
        {
            @Body
        }
        else
        {
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" 
                Class="pt-8 px-6 pb-8">
                    @Body
            </MudContainer>
        }
    </MudMainContent>
</MudLayout>

@code {

    [Inject]
    private ITokenStorageService _tokenStorageService { get; set; } = null!;

    [Inject]
    private IJwtTokenService _jwtTokenService { get; set; } = null!;

    [Inject]
    private IThemeService _themeService { get; set; } = null!;

    private bool _drawerOpen = true;
    private bool _isDarkMode => _themeService.IsDarkMode;
    private bool _isLoggedIn;
    private string? _email;
    private UserRoleType? _role;
    private bool IsLoginPage => Navigation.Uri.Contains("/login");

    protected override void OnInitialized()
    {
        _themeService.ThemeChanged += OnThemeChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUser();
            StateHasChanged();
        }
    }

    private string GetRoleIcon()
    {
        return _role switch
        {
            UserRoleType.Manager =>
                Icons.Material.Filled.AdminPanelSettings,

            UserRoleType.Worker =>
                Icons.Material.Filled.Person,

            UserRoleType.Admin =>
                Icons.Material.Filled.Security,

            _ =>
                Icons.Material.Filled.AccountCircle
        };
    }

    private async Task Logout()
    {
        await _tokenStorageService.RemoveTokenAsync();
        Navigation.NavigateTo("/login", true);
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private void ToggleDarkMode()
    {
        _themeService.Toggle();
    }

    private async Task LoadUser()
    {
        var token = await _tokenStorageService.GetTokenAsync();

        if (string.IsNullOrWhiteSpace(token))
        {
            _isLoggedIn = false;
            return;
        }

        _role = _jwtTokenService.GetRole(token);
        _email = _jwtTokenService.GetEmail(token);
        _isLoggedIn = true;
    }

    public void Dispose()
    {
        _themeService.ThemeChanged -= OnThemeChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Background = "#E8F0F7",
            DrawerBackground = "#D6E3F0",
            Surface = "#F8FAFC",
            AppbarBackground = "#F8FAFC",

            Primary = "#2C5282",
            Secondary = "#2F855A",

            TextPrimary = "#1A202C",
            TextSecondary = "#4A5568"
        },

        PaletteDark = new PaletteDark()
        {
            Background = "#1A202C",
            DrawerBackground = "#2D3748",
            Surface = "#2D3748",
            AppbarBackground = "#2D3748",

            Primary = "#63B3ED",
            TextPrimary = "#EDF2F7",
            TextSecondary = "#A0AEC0",
            Secondary = "#68D391"
        }
    };
}