@page "/stocks/issue"
@using MudBlazor
@using WMS.Application.Stocks.Response
@using WMS.Client.Services.Interfaces
@using WMS.Client.Components.Selectors
@using WMS.Client.Components.Forms
@using WMS.Client.Components.Tables

<PageTitle>Issue Stock</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-6">Issue Stock</MudText>

<IssueStockForm OnSuccess="OnIssueStockFormSuccess" />

<StockTable Items="_stocks" />

@code {
    [Inject]
    private IStockService _stockService { get; set; } = null!;

    [Inject]
    private ISnackbar _snackBar { get; set; } = null!;

    private IEnumerable<StockResponse>? _stocks; 

    protected override async Task OnInitializedAsync()
    {
        await ReloadStocks();
    }

    private async Task ReloadStocks()
    {
        _stocks = await _stockService.GetSummaryAsync(default);
    }

    private async Task OnIssueStockFormSuccess()
    {
        await ReloadStocks();
        _snackBar.Add("Stock issued successfully!", Severity.Success);
    }
}