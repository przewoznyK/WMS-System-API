@page "/Locations"
@using MudBlazor
@using WMS.Application.Stocks.Dtos
@using System.Net.Http.Json
@using WMS.Client.Responses
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<MudThemeProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<PageTitle>WMS Dashboard</PageTitle>

<h3>Add New Location</h3>
<EditForm Model="addLocationForm" OnValidSubmit="HandleSubmit" FormName="AddLocationForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label>Location Code:</label>
        <MudTextField @bind-Value="addLocationForm.Code" 
                      Placeholder="AA-02-10"
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense"
                      Mask="@locationMask"
                      Immediate="true" />
        <ValidationMessage For="@(() => addLocationForm.Code)" class="text-danger" />
    </div>

    <div class="mb-3">
        <label>Description (Optional):</label>
        <MudTextField @bind-Value="addLocationForm.Description" 
                      Placeholder="Enter description (e.g. Rack for heavy items)..."
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense" 
                      Lines="3" /> <ValidationMessage For="@(() => addLocationForm.Description)" class="text-danger" />
    </div>

    <button type="submit" class="btn btn-primary">Add location</button>
</EditForm>

<hr />

<h1>Current locations</h1>

@if (availableLocations == null)
{
        <p><em>Loading warehouse data...</em></p>
}
else if (!availableLocations.Any())
{
        <p>Warehouse is empty.</p>
}
else
{
        <table class="table">
            <thead>
                <tr>
                    <th>Location Code</th> 
                </tr>
            </thead>
            <tbody>
            @foreach (var location in availableLocations)
            {
                        <tr>
                            <td>@location</td>
                        </tr>
            }
            </tbody>
        </table>
}

@code {

    private List<string> availableLocations = new();

    [SupplyParameterFromForm]
    private AddLocationDto addLocationForm { get; set; } = new();

    private IMask locationMask = new PatternMask("XX-00-00")
    {
        MaskChars = new[]
        {
            new MaskChar('X', @"[A-Za-z]"),
            new MaskChar('0', @"[0-9]")
        },
        Transformation = c => char.ToUpperInvariant(c)
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadLocationsAsync();
    }

    private async Task LoadLocationsAsync()
    {
        try
        {
            availableLocations = await Http.GetFromJsonAsync<List<string>>("api/warehouseLocations/locations") ?? new List<string>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error retrieving locations: {ex.Message}");
        }
    }

    private async Task HandleSubmit()
    {
        var response = await Http.PostAsJsonAsync("api/warehouseLocations/create", addLocationForm);

        if (response.IsSuccessStatusCode)
        {
            addLocationForm = new AddLocationDto();
            await LoadLocationsAsync();

            Snackbar.Add("Location added successfully!", Severity.Success);
        }
        else
        {
            var errorJson = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Raw Error: {errorJson}");

            try
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var apiError = System.Text.Json.JsonSerializer.Deserialize<ApiError>(errorJson, options);

                string errorMessage = "Undefined server error.";

                if (apiError?.Errors != null && apiError.Errors.Any())
                {
                    var allErrors = apiError.Errors.SelectMany(e => e.Value);
                    errorMessage = string.Join(" ", allErrors);
                }
                else if (!string.IsNullOrEmpty(apiError?.Details))
                {
                    errorMessage = apiError.Details;
                }
                else if (!string.IsNullOrEmpty(apiError?.Title))
                {
                    errorMessage = apiError.Title;
                }

                Snackbar.Add(errorMessage, Severity.Error);
            }
            catch
            {
                Snackbar.Add("An error occurred while connecting to the API.", Severity.Error);
            }
        }
    }
}