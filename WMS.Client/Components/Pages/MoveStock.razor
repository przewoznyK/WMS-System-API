@page "/stock/move"
@using MudBlazor
@using WMS.Application.Products.Dtos
@using WMS.Application.Stocks.Dtos
@using System.Net.Http.Json
@using WMS.Client.Responses
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudThemeProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudCard Elevation="3">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h5">Internal Stock Transfer</MudText>
        </CardHeaderContent>
    </MudCardHeader>

    <MudCardContent>
        <div class="mb-3">
            <MudTextField @bind-Value="addTransferProductForm.SearchTerm" 
                          Label="Enter Product SKU or Name" 
                          Variant="Variant.Outlined" 
                          Margin="Margin.Dense" 
                          Immediate="true"
                          OnKeyDown="HandleFindProductKeyPress" />

            <MudButton Class="mt-3" Variant="Variant.Filled" Color="Color.Secondary" OnClick="FindProduct">
                Find Product
            </MudButton>
        </div>

        @if (searchProduct != null)
        {
                <MudDivider Class="my-4" />

                <MudText Typo="Typo.subtitle1" Color="Color.Success" Class="mb-3">
                    Product found: @searchProduct.Name (@searchProduct.Sku)
                </MudText>

                <EditForm Model="addTransferProductForm" OnValidSubmit="TransferProduct" FormName="AddTransferForm">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label>Source Location Code:</label>
                        <MudAutocomplete T="StockDto" 
                                         Value="selectedSourceStock"
                                         ValueChanged="OnStockSelected"
                                         SearchFunc="@SearchLocationsBySku"
                                         ToStringFunc="@(stock => stock?.LocationCode)" 
                                         ResetValueOnEmptyText="true"
                                         CoerceText="true" 
                                         CoerceValue="true"
                                         Placeholder="Enter or select a source location code..."
                                         Variant="Variant.Outlined" 
                                         Margin="Margin.Dense">

                            <ItemTemplate Context="stock">
                                <div class="d-flex justify-space-between" style="width: 100%; gap: 20px;">
                                    <MudText>@stock.LocationCode</MudText>
                                    <MudText Color="Color.Success">Available: <b>@stock.Quantity</b> pcs.</MudText>
                                </div>
                            </ItemTemplate>
                        </MudAutocomplete>
                        <ValidationMessage For="@(() => addTransferProductForm.SourceLocationCode)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label>Quantity to Transfer:</label>
                        <MudNumericField @bind-Value="addTransferProductForm.Quantity"
                                         Min="1"
                                         Max="@(selectedSourceStock?.Quantity ?? int.MaxValue)"
                                         Disabled="@(selectedSourceStock == null)"
                                         Variant="Variant.Outlined" 
                                         Margin="Margin.Dense"
                                         Adornment="Adornment.End"
                                         AdornmentText="@(selectedSourceStock != null ? $"Max: {selectedSourceStock.Quantity} pcs." : "")" />
                        <ValidationMessage For="@(() => addTransferProductForm.Quantity)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label>Destination Location Code:</label>
                        <MudAutocomplete T="string"
                                         @bind-Value="addTransferProductForm.DestinationLocationCode"
                                         SearchFunc="@SearchLocations"
                                         Placeholder="Enter or select a destination location code..."
                                         Variant="Variant.Outlined" 
                                         Margin="Margin.Dense">
                        </MudAutocomplete>
                        <ValidationMessage For="@(() => addTransferProductForm.DestinationLocationCode)" class="text-danger" />
                    </div>

                    <MudButton ButtonType="ButtonType.Submit" Class="mt-4" Variant="Variant.Filled" Color="Color.Primary">
                        Transfer Product
                    </MudButton>
                </EditForm>
        }
    </MudCardContent>
</MudCard>

@code {
    [SupplyParameterFromForm]
    private MoveStockRequest addTransferProductForm { get; set; } = new();

    private ProductDto? searchProduct;
    private StockDto? selectedSourceStock;
    private List<StockDto> availableStocks = new();
    private List<string> availableLocations = new();

    private IMask locationMask = new PatternMask("XX-00-00")
        {
            MaskChars = new[]
            {
            new MaskChar('X', @"[A-Za-z]"),
            new MaskChar('0', @"[0-9]")
        },
            Transformation = c => char.ToUpperInvariant(c)
        };

    protected override async Task OnInitializedAsync()
    {
        await LoadLocationsAsync();
    }

    private async Task LoadLocationsAsync()
    {
        try
        {
            availableLocations = await Http.GetFromJsonAsync<List<string>>("api/WarehouseLocations/locations") ?? new List<string>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error retrieving locations: {ex.Message}");
        }
    }

    private Task<IEnumerable<string>> SearchLocations(string value, CancellationToken token)
    {
        var validLocations = availableLocations
            .Where(loc => !string.Equals(loc, addTransferProductForm.SourceLocationCode, StringComparison.InvariantCultureIgnoreCase));

        if (string.IsNullOrEmpty(value))
            return Task.FromResult(validLocations);

        var filteredList = validLocations.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
        return Task.FromResult(filteredList);
    }

    private async Task HandleFindProductKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "NumpadEnter")
        {
            await FindProduct();
        }
    }

    private async Task FindProduct()
    {
        if (string.IsNullOrWhiteSpace(addTransferProductForm.SearchTerm)) return;

        try
        {
            searchProduct = await Http.GetFromJsonAsync<ProductDto>($"api/products/search/{addTransferProductForm.SearchTerm}");
            await LoadStocksAsync();
        }
        catch
        {
            searchProduct = null;
            availableStocks.Clear();
            Snackbar.Add("Product not found", Severity.Error);
        }
    }

    private async Task LoadStocksAsync()
    {
        try
        {
            if (searchProduct == null || string.IsNullOrWhiteSpace(searchProduct.Sku)) return;

            availableStocks = await Http.GetFromJsonAsync<List<StockDto>>($"api/stocks/by-product-sku/{searchProduct.Sku}") ?? new List<StockDto>();
            addTransferProductForm.ProductSku = searchProduct.Sku;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error retrieving locations: {ex.Message}");
        }
    }

    private Task<IEnumerable<StockDto>> SearchLocationsBySku(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
        {
            return Task.FromResult<IEnumerable<StockDto>>(availableStocks);
        }

        var filteredList = availableStocks
            .Where(x => x.LocationCode != null && x.LocationCode.Contains(value, StringComparison.InvariantCultureIgnoreCase));

        return Task.FromResult<IEnumerable<StockDto>>(filteredList);
    }

    private void OnStockSelected(StockDto stock)
    {
        selectedSourceStock = stock;
        addTransferProductForm.SourceLocationCode = stock?.LocationCode ?? string.Empty;

        if (string.Equals(addTransferProductForm.DestinationLocationCode, addTransferProductForm.SourceLocationCode, StringComparison.InvariantCultureIgnoreCase))
        {
            addTransferProductForm.DestinationLocationCode = string.Empty;
        }

        if (addTransferProductForm.Quantity <= 0 && stock != null && stock.Quantity > 0)
        {
            addTransferProductForm.Quantity = 1;
        }

        if (stock != null && addTransferProductForm.Quantity > stock.Quantity)
        {
            addTransferProductForm.Quantity = stock.Quantity;
        }
    }

    private async Task TransferProduct()
    {
        Console.WriteLine(System.Text.Json.JsonSerializer.Serialize(addTransferProductForm));
        var response = await Http.PostAsJsonAsync("api/stocks/move", addTransferProductForm);

        if (response.IsSuccessStatusCode)
        {
            await LoadStocksAsync();
            addTransferProductForm = new MoveStockRequest();
            searchProduct = null;
            selectedSourceStock = null;
            availableStocks.Clear();
            Snackbar.Add("Stock added successfully!", Severity.Success);
        }
        else
        {
            var errorJson = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Raw Error: {errorJson}");

            try
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var apiError = System.Text.Json.JsonSerializer.Deserialize<ApiError>(errorJson, options);

                string errorMessage = !string.IsNullOrEmpty(apiError?.Details) ? apiError.Details :
                                      !string.IsNullOrEmpty(apiError?.Title) ? apiError.Title :
                                      "Undefined server error.";

                Snackbar.Add(errorMessage, Severity.Error);
            }
            catch
            {
                Snackbar.Add("An error occurred while connecting to the API.", Severity.Error);
            }
        }
    }
}