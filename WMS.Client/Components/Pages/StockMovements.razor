@page "/stockmovements"

@using WMS.Application.StockMovements.Response
@using WMS.Client.Components.Tables
@using WMS.Client.Services.Interfaces
@using WMS.Client.Components.Base

@inherits CancellableComponentBase

<PageTitle>Stock Movements</PageTitle>
<StockMovementsTable Items="_movements" 
                     InitialSearch="@Search" />

@code {
    [Inject]
    private IStockMovementService _stockMovementService { get; set; } = null!;

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Search { get; set; }

    private IEnumerable<StockMovementResponse>? _movements;

    protected override async Task OnInitializedAsync()
    {
        _movements = await _stockMovementService.GetSummaryAsync(CancellationToken);
    }
}