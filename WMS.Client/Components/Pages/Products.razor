@page "/products"
@using MudBlazor
@using WMS.Application.Products.Dtos
@using System.Net.Http.Json
@using WMS.Client.Responses
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager NavManager

<MudThemeProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<PageTitle>WMS Dashboard</PageTitle>

<h3>Add New Product</h3>
<EditForm Model="addProductForm" OnValidSubmit="HandleSubmit" FormName="AddProductForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label>SKU:</label>
        <MudTextField @bind-Value="addProductForm.Sku" 
                      Placeholder="Enter SKU (e.g. PROD-001)..."
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense" 
                      Immediate="true" />
        <ValidationMessage For="@(() => addProductForm.Sku)" class="text-danger" />
    </div>

    <div class="mb-3">
        <label>Product Name:</label>
        <MudTextField @bind-Value="addProductForm.Name" 
                      Placeholder="Enter product name..."
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense" />
        <ValidationMessage For="@(() => addProductForm.Name)" class="text-danger" />
    </div>

    <div class="mb-3">
        <label>Description (Optional):</label>
        <MudTextField @bind-Value="addProductForm.Description" 
                      Placeholder="Enter product description..."
                      Variant="Variant.Outlined" 
                      Margin="Margin.Dense" 
                      Lines="3" />
        <ValidationMessage For="@(() => addProductForm.Description)" class="text-danger" />
    </div>

    <button type="submit" class="btn btn-primary">Add Product</button>
</EditForm>

<hr />

<h1>Current locations</h1>

@if (availableProducts == null)
{
    <p><em>Loading warehouse data...</em></p>
}
else if (!availableProducts.Any())
{
    <p>Warehouse is empty.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Sku</th> 
                <th>Name</th> 
                <th>Description</th> 
            </tr>
        </thead>
        <tbody>
    @foreach (var product in availableProducts)
    {
        <tr>
            <td>@product.Sku</td>
            <td>@product.Name</td>
            <td>@product.Description</td>
        </tr>
    }
        </tbody>
    </table>
}

@code {

    private List<ProductDto> availableProducts = new();

    [SupplyParameterFromForm]
    private AddProductDto addProductForm { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLocationsAsync();
    }

    private async Task LoadLocationsAsync()
    {
        try
        {
            availableProducts = await Http.GetFromJsonAsync<List<ProductDto>>("api/products/summary") ?? new List<ProductDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error retrieving products: {ex.Message}");
        }
    }

    private async Task HandleSubmit()
    {
        var response = await Http.PostAsJsonAsync("api/products/create", addProductForm);

        if (response.IsSuccessStatusCode)
        {
            addProductForm = new AddProductDto();
            await LoadLocationsAsync();

            Snackbar.Add("Product added successfully!", Severity.Success);
        }
        else
        {
            var errorJson = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Raw Error: {errorJson}");

            try
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var apiError = System.Text.Json.JsonSerializer.Deserialize<ApiError>(errorJson, options);

                string errorMessage = "Undefined server error.";

                if (apiError?.Errors != null && apiError.Errors.Any())
                {
                    var allErrors = apiError.Errors.SelectMany(e => e.Value);
                    errorMessage = string.Join(" ", allErrors);
                }
                else if (!string.IsNullOrEmpty(apiError?.Details))
                {
                    errorMessage = apiError.Details;
                }
                else if (!string.IsNullOrEmpty(apiError?.Title))
                {
                    errorMessage = apiError.Title;
                }

                Snackbar.Add(errorMessage, Severity.Error);
            }
            catch
            {
                Snackbar.Add("An error occurred while connecting to the API.", Severity.Error);
            }
        }
    }
}