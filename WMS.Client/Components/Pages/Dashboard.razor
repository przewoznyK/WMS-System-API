@page "/"
@using MudBlazor
@using WMS.Client.Components.Cards
@using WMS.Application.Dashboard.Responses
@using WMS.Application.StockMovements.Responses
@using WMS.Client.Services.Interfaces
@using WMS.Client.Components.Base
@using WMS.Client.Components.Tables

@inherits CancellableComponentBase

@inject NavigationManager NavManager

<MudGrid Class="mb-8">
    @if (_dashboard == null)
    {
        <MudText>
            Loading dashboard...
        </MudText>
    }
    else
    {
        <MudItem xs="12" sm="6" lg="3">

            <DashboardStatCard
                Title="Products"
                Value="@_dashboard.ProductCount"
                Icon="@Icons.Material.Filled.Category"
                Color="Color.Primary"
                Href="/products" />

        </MudItem>

        <MudItem xs="12" sm="6" lg="3">

            <DashboardStatCard
                Title="Locations"
                Value="@_dashboard.LocationCount"
                Icon="@Icons.Material.Filled.Warehouse"
                Color="Color.Info"
                Href="/locations" />

        </MudItem>

        <MudItem xs="12" sm="6" lg="3">

            <DashboardStatCard
                Title="Stock Quantity"
                Value="@_dashboard.StockQuantity"
                Color="Color.Success"
                Href="/stocks" />

        </MudItem>

        <MudItem xs="12" sm="6" lg="3">

            <DashboardStatCard
                Title="Today Movements"
                Value="@_dashboard.TodayMovements"
                Icon="@Icons.Material.Filled.SwapHoriz"
                Color="Color.Secondary"
                    Href="@($"/stockmovements?search={DateTime.Today:yyyy-MM-dd}")" />

        </MudItem>

        <MudItem xs="12" sm="6" lg="3">

            <DashboardStatCard
                Title="Low Stock"
                Value="@_dashboard.LowStockCount"
                Icon="@Icons.Material.Filled.Warning"
                Color="Color.Warning"
                Href="stocks/low-stock"/>

        </MudItem>
    }
</MudGrid>

<MudItem xs="12">

    <MudCard Elevation="2" Class="pa-4 mt-4">

        <MudStack Row="true"
                  Justify="Justify.SpaceBetween"
                  AlignItems="AlignItems.Center">

            <MudText Typo="Typo.h5">
                Stock Movement Activity
            </MudText>

            <MudButtonGroup Variant="Variant.Outlined">

                <MudButton OnClick="@(() => LoadChartAsync(7))">
                    7 Days
                </MudButton>

                <MudButton OnClick="@(() => LoadChartAsync(14))">
                    14 Days
                </MudButton>

                <MudButton OnClick="@(() => LoadChartAsync(30))">
                    30 Days
                </MudButton>

            </MudButtonGroup>

        </MudStack>

        <MudDivider Class="my-4" />

        @if (_movementChart == null)
        {
                <MudProgressCircular Indeterminate="true" />
        }
        else
        {
                <!-- tutaj później wykres -->

                <MudTable Items="_movementChart"
                          Dense="true"
                          Hover="true"
                          Elevation="0">

                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Receive</MudTh>
                        <MudTh>Issue</MudTh>
                        <MudTh>Transfer</MudTh>
                    </HeaderContent>

                    <RowTemplate>

                        <MudTd>
                        @context.Date.ToString("yyyy-MM-dd")
                        </MudTd>

                        <MudTd>
                        @context.Receive
                        </MudTd>

                        <MudTd>
                        @context.Issue
                        </MudTd>

                        <MudTd>
                        @context.Transfer
                        </MudTd>

                    </RowTemplate>

                </MudTable>
        }

    </MudCard>

</MudItem>

@code {
    [Inject]
    private IDashboardService _dashboardService { get; set; } = null!;

    [Inject]
    private IStockMovementService _stockMovementService { get; set; } = null!;

    private DashboardSummaryResponse? _dashboard;
    private IEnumerable<MovementChartResponse>? _movementChart;

    protected override async Task OnInitializedAsync()
    {
        _dashboard = await _dashboardService.GetSummaryAsync(CancellationToken);

        _movementChart = await _stockMovementService.GetChartAsync(7, CancellationToken);
    }

    private async Task LoadChartAsync(int days)
    {
        _movementChart = await _stockMovementService
            .GetChartAsync(days, CancellationToken);
    }
}