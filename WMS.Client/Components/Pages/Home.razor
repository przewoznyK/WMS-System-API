@page "/"
@using MudBlazor
@inject NavigationManager NavManager

<PageTitle>WMS Dashboard</PageTitle>

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-2"><b>Warehouse Dashboard</b></MudText>
<MudText Typo="Typo.subtitle1" Color="Color.Default" Class="mb-8">Select an operation to get started.</MudText>

<MudText Typo="Typo.h5" Color="Color.Secondary" Class="mb-4 mt-4"><b>Daily Operations</b></MudText>
<MudGrid Class="mb-8">

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Class="dashboard-tile" @onclick='() => NavigateTo("/stocks/receive")'>
            <MudCardContent Class="d-flex flex-column align-center justify-center pa-6">
                <MudIcon Icon="@Icons.Material.Filled.MoveToInbox" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                <MudText Typo="Typo.h6" Align="Align.Center">Receive Stock</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">Receive items into warehouse</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Class="dashboard-tile" @onclick='() => NavigateTo("/stocks/issue")'>
            <MudCardContent Class="d-flex flex-column align-center justify-center pa-6">
                <MudIcon Icon="@Icons.Material.Filled.Outbox" Size="Size.Large" Color="Color.Error" Class="mb-3" />
                <MudText Typo="Typo.h6" Align="Align.Center">Issue Stock</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">Release items from warehouse</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Class="dashboard-tile" @onclick='() => NavigateTo("/stocks/move")'>
            <MudCardContent Class="d-flex flex-column align-center justify-center pa-6">
                <MudIcon Icon="@Icons.Material.Filled.SyncAlt" Size="Size.Large" Color="Color.Info" Class="mb-3" />
                <MudText Typo="Typo.h6" Align="Align.Center">Transfer</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">Move items between locations</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="2" Class="dashboard-tile" @onclick='() => NavigateTo("/stockmovements")'>
            <MudCardContent Class="d-flex flex-column align-center justify-center pa-6">
                <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Color="Color.Default" Class="mb-3" />
                <MudText Typo="Typo.h6" Align="Align.Center">Movements</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">View operations history</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

</MudGrid>

<MudDivider Class="my-6" />

<MudText Typo="Typo.h5" Color="Color.Secondary" Class="mb-4"><b>Management & Administration</b></MudText>
<MudGrid>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="dashboard-tile" @onclick='() => NavigateTo("/products")'>
            <MudCardContent Class="d-flex flex-column align-center justify-center pa-6">
                <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Large" Color="Color.Warning" Class="mb-3" />
                <MudText Typo="Typo.h6" Align="Align.Center">Products</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">Manage product catalog</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="2" Class="dashboard-tile" @onclick='() => NavigateTo("/locations")'>
            <MudCardContent Class="d-flex flex-column align-center justify-center pa-6">
                <MudIcon Icon="@Icons.Material.Filled.Place" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
                <MudText Typo="Typo.h6" Align="Align.Center">Locations</MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">Manage warehouse structure</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

</MudGrid>

<style>
    .dashboard-tile {
        cursor: pointer;
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        height: 100%;
    }
    .dashboard-tile:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

@code {
    private void NavigateTo(string url)
    {
        NavManager.NavigateTo(url);
    }
}