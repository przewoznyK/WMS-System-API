@page "/"
@inject HttpClient Http
@using System.Net.Http.Json
@using WMS.Application.Stocks.Dtos

<PageTitle>Home</PageTitle>

<h1>Current stock level</h1>

@if (stocks == null)
{
        <p><em>Loading warehouse data...</em></p>
}
else if (!stocks.Any())
{
        <p>Warehouse is empty.</p>
}
else
{
        <table class="table">
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Location Code</th>
                    <th>Quantity</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var stock in stocks)
            {
                        <tr>
                            <td>@stock.ProductName</td>
                            <td>@stock.LocationCode</td>
                            <td>@stock.Quantity</td>
                        </tr>
            }
            </tbody>
        </table>
}

@code {
    private List<StockDto>? stocks;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("api/stocks/summary");

            if (response.IsSuccessStatusCode)
            {
                stocks = await response.Content.ReadFromJsonAsync<List<StockDto>>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                Console.WriteLine("Data not found (404).");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"API error: {error}");
            }
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"Connection error: {ex.Message}");
        }
    }
}