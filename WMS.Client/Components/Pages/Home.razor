@page "/"
@using MudBlazor
@using WMS.Application.Stocks.Dtos
@using System.Net.Http.Json
@using WMS.Client.Responses
@inject HttpClient Http
@inject ISnackbar Snackbar
<MudThemeProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<PageTitle>WMS Dashboard</PageTitle>

<h3>Receive New Stock</h3>
<EditForm Model="stockForm" OnValidSubmit="HandleSubmit" FormName="AddStockForm">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label>Product Name:</label>
        <MudAutocomplete T="string" 
                         @bind-Value="stockForm.ProductName" 
                         SearchFunc="@SearchProductNames"
                         ResetValueOnEmptyText="true"
                         CoerceText="true" 
                         CoerceValue="true"
                         Placeholder="Enter or select a product name..."
                         Variant="Variant.Outlined" 
                         Margin="Margin.Dense" />
        <ValidationMessage For="@(() => stockForm.ProductName)" class="text-danger" />
    </div>

    <div class="mb-3">
        <label>Location Code:</label>
        <MudAutocomplete T="string" 
                         @bind-Value="stockForm.LocationCode" 
                         SearchFunc="@SearchLocations"
                         ResetValueOnEmptyText="true"
                         CoerceText="true" 
                         CoerceValue="true"
                         Placeholder="Enter or select a location..."
                         Variant="Variant.Outlined" 
                         Margin="Margin.Dense" />
        <ValidationMessage For="@(() => stockForm.LocationCode)" class="text-danger" />
    </div>

    <div class="mb-3">
        <label>Quantity:</label>
        <InputNumber @bind-Value="stockForm.Quantity" class="form-control" />
        <ValidationMessage For="@(() => stockForm.Quantity)" class="text-danger" />
    </div>

    <button type="submit" class="btn btn-primary">Receive Stock</button>
</EditForm>

<hr />

<h1>Current stock level</h1>

@if (stocks == null)
{
        <p><em>Loading warehouse data...</em></p>
}
else if (!stocks.Any())
{
        <p>Warehouse is empty.</p>
}
else
{
        <table class="table">
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Location Code</th>
                    <th>Quantity</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var stock in stocks)
            {
                        <tr>
                            <td>@stock.ProductName</td>
                            <td>@stock.LocationCode</td>
                            <td>@stock.Quantity</td>
                        </tr>
            }
            </tbody>
        </table>
}

@code {
    private List<StockDto>? stocks;
    [SupplyParameterFromForm]
    private ReceiveStockDto stockForm { get; set; } = new();

    private List<string> availableLocations = new();
    private List<string> availableProductNames = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadStocksAsync();
        await LoadProductNamesAsync();
        await LoadLocationsAsync();
    }

    private async Task LoadProductNamesAsync()
    {
        try
        {
            availableProductNames = await Http.GetFromJsonAsync<List<string>>("api/Products/names") ?? new List<string>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error retrieving product names: {ex.Message}");
        }
    }

    private Task<IEnumerable<string>> SearchProductNames(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<string>>(availableProductNames);

        var filteredList = availableProductNames.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
        return Task.FromResult<IEnumerable<string>>(filteredList);
    }

    private async Task LoadLocationsAsync()
    {
        try
        {
            availableLocations = await Http.GetFromJsonAsync<List<string>>("api/WarehouseLocations/locations") ?? new List<string>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error retrieving locations: {ex.Message}");
        }
    }

    private Task<IEnumerable<string>> SearchLocations(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value))
            return Task.FromResult<IEnumerable<string>>(availableLocations);

        var filteredList = availableLocations.Where(x => x.Contains(value, StringComparison.InvariantCultureIgnoreCase));
        return Task.FromResult<IEnumerable<string>>(filteredList);
    }

    private async Task LoadStocksAsync()
    {
        try
        {
            stocks = await Http.GetFromJsonAsync<List<StockDto>>("api/stocks/summary");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
    }

    private async Task HandleSubmit()
    {
        var response = await Http.PostAsJsonAsync("api/stocks/receive", stockForm);

        if (response.IsSuccessStatusCode)
        {
            stockForm = new ReceiveStockDto();
            await LoadStocksAsync();
            Console.WriteLine("Stock received successfully!");
            Snackbar.Add("Stock added successfully!", Severity.Success);
        }
        else
        {
            var errorJson = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Raw Error: {errorJson}");

            try
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var apiError = System.Text.Json.JsonSerializer.Deserialize<ApiError>(errorJson, options);

                string errorMessage = !string.IsNullOrEmpty(apiError?.Details) ? apiError.Details :
                                      !string.IsNullOrEmpty(apiError?.Title) ? apiError.Title :
                                      "Undefined server error.";

                Snackbar.Add(errorMessage, Severity.Error);
            }
            catch
            {
                Snackbar.Add("An error occurred while connecting to the API.", Severity.Error);
            }
        }
    }
}