@page "/history"
@using MudBlazor
@using WMS.Application.StockMovements.Dtos
@using System.Net.Http.Json
@inject HttpClient Http

<MudThemeProvider />
<MudSnackbarProvider />
<MudPopoverProvider />
<PageTitle>Stock Movement</PageTitle>

<MudTable Items="@movements" 
          Hover="true" 
          Dense="true"
          Filter="new Func<StockMovementDto, bool>(FilterFunc)">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Stock Movement</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString" 
                      Placeholder="Search..." 
                      Adornment="Adornment.Start" 
                      AdornmentIcon="@Icons.Material.Filled.Search" 
                      IconSize="Size.Medium" 
                      Class="mt-0" />
    </ToolBarContent>

    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<StockMovementDto, object>(x => x.CreatedAt)" InitialDirection="SortDirection.Descending">Data</MudTableSortLabel></MudTh>
        <MudTh>SKU</MudTh>
        <MudTh>Product Name</MudTh>
        <MudTh>Location</MudTh>
        <MudTh>Operation Type</MudTh>
        <MudTh>Quantity</MudTh>
    </HeaderContent>

    <RowTemplate>
        <MudTd DataLabel="Data">@context.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudTd>

        <MudTd DataLabel="SKU">@context.ProductSku</MudTd>

        <MudTd DataLabel="Product Name">@context.ProductName</MudTd>

        <MudTd DataLabel="Location">@context.LocationCode</MudTd>
        
     <MudTd DataLabel="OperationType">
    <MudChip T="string" 
             Color="@GetOperationColor(context.OperationType.ToString())" 
             Size="Size.Small" 
             Variant="Variant.Filled">
                @context.OperationType.ToString()
    </MudChip>
</MudTd>

        <MudTd DataLabel="Quantity">
            <MudText Color="@(context.QuantityChange > 0 ? Color.Success : context.QuantityChange < 0 ? Color.Error : Color.Default)" Typo="Typo.body2">
                @(context.QuantityChange > 0 ? $"+{context.QuantityChange}" : context.QuantityChange.ToString())
            </MudText>
        </MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

 @code {
     private List<StockMovementDto> movements = new();
     private string searchString = "";

     protected override async Task OnInitializedAsync()
     {
        try
        {
            movements = await Http.GetFromJsonAsync<List<StockMovementDto>>("api/stocks/summary") ?? new List<StockMovementDto>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
     }

     private bool FilterFunc(StockMovementDto element)
     {
         if (string.IsNullOrWhiteSpace(searchString)) return true;
         if (element.ProductSku.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
         if (element.LocationCode.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;

         return false;
     }

    private Color GetOperationColor(string operationType)
    {
        return (operationType ?? string.Empty) switch
        {
            "receive" => Color.Success,
            "issue" => Color.Error,
            "transfer" => Color.Info,
            "adjustment" => Color.Primary,
            _ => Color.Default
        };
    }
 }