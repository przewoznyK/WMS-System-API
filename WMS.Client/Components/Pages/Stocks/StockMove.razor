@page "/stocks/move"
@using WMS.Client.Components.Forms
@using WMS.Client.Components.Tables
@using WMS.Client.Services.Interfaces
@using WMS.Application.StockMovements.Response
@using WMS.Client.Components.Base

@inherits CancellableComponentBase

<PageTitle> Internal Stock Transfer </PageTitle>

<MoveStockForm OnSuccess="OnMoveStockFormSuccess" />

@if (_selectedProductSku != null)
{
    <MudCard Elevation="2" Class="pa-4">
        <StockMovementsTable Items="_movements" />
    </MudCard>
}

@code {
    [Inject]
    private IStockMovementService StockMovementService { get; set; } = null!;

    [Inject]
    private ISnackbar _snackBar { get; set; } = null!;

    private string? _selectedProductSku;
    private IEnumerable<StockMovementResponse>? _movements;

    private async Task ReloadHistory(string sku)
    {
        _selectedProductSku = sku;
        var all = await StockMovementService.GetSummaryAsync(CancellationToken);

        _movements = all
            .Where(x => x.ProductSku == sku);
    }

    private async Task OnMoveStockFormSuccess(string sku)
    {
        await ReloadHistory(sku);

        _snackBar.Add("Product moved successfully!", Severity.Success);
    }
}