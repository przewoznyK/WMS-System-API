          "name": "[POST] Login as manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 OK\", function () \r",
                  "{\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200) \r",
                  "{\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.collectionVariables.set(\"jwtToken\", jsonData.token);\r",
                  "    console.log(\"SUCCESS: Logged in as manager. Token updated.\");\r",
                  "} \r",
                  "else \r",
                  "{\r",
                  "    var errorDetails = pm.response.text();\r",
                  "    console.error(\"ERROR: Login failed. Status: \" + pm.response.code + \" (\" + pm.response.status + \")\");\r",
                  "    console.error(\"SERVER ERROR DETAILS: \" + errorDetails);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"manager@wms.com\",\r\n  \"password\": \"Password123!\"\r\n}",
